<% layout('/layouts/boilerplate') %>
<style>
    #adminUserSearch::placeholder { 
        color: var(--text-muted) !important; 
        opacity: 0.7; 
    }
</style>

<div class="container mt-5 mb-5 pb-5">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h2 class="fw-bold m-0" style="font-family: var(--font-display);"><i class="fa-solid fa-shield-halved me-3" style="color: var(--primary);"></i>Admin Dashboard</h2>
            <span class="text-muted" id="userCountIndicator"><%= users ? users.length : 0 %> Registered Users</span>
        </div>
        <div class="col-md-6 mt-3 mt-md-0">
            <div class="input-group border" style="border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-sm); border-color: var(--bg-tertiary) !important;">
                <span class="input-group-text border-0" style="background-color: var(--bg-secondary); color: var(--text-muted);"><i class="fa-solid fa-magnifying-glass"></i></span>
                <input type="text" id="adminUserSearch" class="form-control border-0" placeholder="Search by name, @username, or email..." onkeyup="filterUsers()" style="background-color: var(--bg-secondary); color: var(--text-dark); box-shadow: none;">
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-md" style="border-radius: var(--radius-xl); overflow: hidden; background-color: var(--bg-main);">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="usersTable" style="--bs-table-bg: transparent; --bs-table-color: var(--text-dark); color: var(--text-dark);">
                    <thead style="background-color: var(--bg-tertiary); color: var(--text-dark);">
                        <tr>
                            <th class="ps-4 py-3 border-0">User Details</th>
                            <th class="py-3 border-0">Role</th>
                            <th class="py-3 border-0">Account Status</th>
                            <th class="py-3 border-0 text-center">Admin Controls</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(users && users.length > 0) { %>
                            <% for(let u of users) { %>
                                <% const prof = profileMap[u._id.toString()]; %>
                                <tr class="user-row" style="transition: background-color 0.2s;" onmouseover="this.style.backgroundColor='var(--bg-tertiary)'" onmouseout="this.style.backgroundColor='transparent'">
                                    <!-- User Info (Clickable link to profile viewer route) -->
                                    <td class="ps-4 py-3 border-0" style="border-bottom: 1px solid var(--bg-tertiary) !important;">
                                        <a href="/profile/public/<%= u._id %>" class="text-decoration-none d-flex align-items-center gap-3">
                                            <% if(prof && prof.profileImg && prof.profileImg.url) { %>
                                                <img src="<%= prof.profileImg.url %>" alt="avatar" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;">
                                            <% } else { %>
                                                <div style="width: 40px; height: 40px; border-radius: 50%; background-color: var(--text-dark); color: white; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                                                    <%= u.username.charAt(0).toUpperCase() %>
                                                </div>
                                            <% } %>
                                            <div>
                                                <p class="mb-0 fw-bold fw-semibold search-target" style="color: inherit;"><%= prof && prof.fullName ? prof.fullName : u.username %></p>
                                                <p class="mb-0 text-muted small search-target">@<%= u.username %> &bull; <%= u.email %></p>
                                            </div>
                                        </a>
                                    </td>

                                    <!-- Role -->
                                    <td class="py-3 border-0" style="border-bottom: 1px solid var(--bg-tertiary) !important;">
                                        <% if(u.role === 'admin') { %>
                                            <span class="badge rounded-pill bg-primary text-white" style="padding: 0.5rem 0.8rem;">
                                                <i class="fa-solid fa-shield-halved me-1"></i>Admin
                                            </span>
                                        <% } else { %>
                                            <span class="badge rounded-pill" style="padding: 0.5rem 0.8rem; background-color: var(--bg-secondary); color: var(--text-dark); border: 1px solid var(--bg-tertiary);">
                                                <i class="fa-solid fa-user me-1"></i><%= u.role.charAt(0).toUpperCase() + u.role.slice(1) %>
                                            </span>
                                        <% } %>
                                    </td>

                                    <!-- Status Badges -->
                                    <td class="py-3 border-0" style="border-bottom: 1px solid var(--bg-tertiary) !important;">
                                        <div class="d-flex flex-column gap-1">
                                            <% if(u.isDisabled) { %>
                                                <span class="badge rounded-pill bg-danger shadow-sm" style="width: fit-content; padding: 0.4rem 0.7rem;"><i class="fa-solid fa-lock me-1"></i>Login Disabled</span>
                                            <% } %>
                                            <% if(u.listingRestricted) { %>
                                                <span class="badge rounded-pill text-dark shadow-sm" style="background-color: #ffc107; width: fit-content; padding: 0.4rem 0.7rem;"><i class="fa-solid fa-ban me-1"></i>Listings Blocked</span>
                                            <% } %>
                                            <% if(!u.isDisabled && !u.listingRestricted) { %>
                                                <span class="badge rounded-pill bg-success shadow-sm" style="width: fit-content; padding: 0.4rem 0.7rem;"><i class="fa-solid fa-circle-check me-1"></i>Active User</span>
                                            <% } %>
                                        </div>
                                    </td>

                                    <!-- Actions -->
                                    <td class="py-3 text-center border-0" style="border-bottom: 1px solid var(--bg-tertiary) !important;">
                                        <div class="d-flex gap-2 justify-content-center">
                                            
                                            <!-- Toggle Login Block -->
                                            <form method="POST" action="/admin/users/<%= u._id %>/toggle?_method=PATCH">
                                                <input type="hidden" name="field" value="isDisabled">
                                                <input type="hidden" name="value" value="<%= !u.isDisabled %>">
                                                <button class="btn btn-sm text-white shadow-sm <%= u.isDisabled ? 'btn-success' : 'btn-danger' %>" style="border-radius: var(--radius-sm); padding: 0.35rem 0.6rem;" title="<%= u.isDisabled ? 'Enable Login' : 'Disable Login' %>">
                                                    <i class="fa-solid <%= u.isDisabled ? 'fa-unlock' : 'fa-lock' %>"></i>
                                                </button>
                                            </form>

                                            <!-- Toggle Listing Block -->
                                            <form method="POST" action="/admin/users/<%= u._id %>/toggle?_method=PATCH">
                                                <input type="hidden" name="field" value="listingRestricted">
                                                <input type="hidden" name="value" value="<%= !u.listingRestricted %>">
                                                <button class="btn btn-sm shadow-sm <%= u.listingRestricted ? 'btn-success text-white' : 'btn-warning text-dark' %>" style="border-radius: var(--radius-sm); padding: 0.35rem 0.6rem;" title="<%= u.listingRestricted ? 'Allow Listings' : 'Restrict Listings' %>">
                                                    <i class="fa-solid <%= u.listingRestricted ? 'fa-pen-clip' : 'fa-ban' %>"></i>
                                                </button>
                                            </form>

                                            <!-- Hard Delete User -->
                                            <form method="POST" action="/admin/users/<%= u._id %>?_method=DELETE" onsubmit="return confirm('WARNING: Are you absolutely sure you want to delete this user and all their listings? This data cannot be recovered.');">
                                                <button class="btn btn-sm btn-outline-danger shadow-sm" style="border-radius: var(--radius-sm); padding: 0.35rem 0.6rem;" title="Delete User">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </button>
                                            </form>

                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">No other users found.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    function filterUsers() {
        const input = document.getElementById('adminUserSearch').value.toLowerCase();
        const rows = document.querySelectorAll('.user-row');
        let count = 0;

        rows.forEach(row => {
            const textContent = Array.from(row.querySelectorAll('.search-target'))
                                     .map(el => el.textContent.toLowerCase())
                                     .join(' ');
            
            if (textContent.includes(input)) {
                row.style.display = '';
                count++;
            } else {
                row.style.display = 'none';
            }
        });

        document.getElementById('userCountIndicator').innerText = input === '' 
            ? `${rows.length} Registered Users` 
            : `Showing ${count} of ${rows.length} Users`;
    }
</script>
