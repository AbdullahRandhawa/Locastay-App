<% layout("/layouts/boilerplate") %>

  <div id="listing-data" data-listing="<%= JSON.stringify(idListing) %>" style="display:none"></div>
  <script>
    window.mapToken = "<%= process.env.MAP_TOKEN %>";
    window.listing = JSON.parse(document.getElementById('listing-data').dataset.listing);
  </script>
  <script>window.onload = function () { window.scrollTo(0, 0); };</script>

  <% locals.showBackBtn = true; %>

  <div class="row">

    <!-- ── HEADER ── -->
    <div class="col-12 col-lg-8 col-md-10 offset-lg-2 offset-md-1 px-3 px-md-0">
      <br />
      <div class="show-header">
        <h3 class="show-page-title">
          <%= idListing.title %>
        </h3>
        <div class="show-badge-strip">
          <% if(idListing.mainCategory) { %>
            <span class="badge badge-category"><%= idListing.mainCategory %></span>
          <% } %>
          <% if(idListing.subCategory) { %>
            <span class="badge badge-sub"><%= idListing.subCategory %></span>
          <% } %>
          <% if(idListing.listingType) { %>
            <span class="badge <%= idListing.listingType === 'Rent' ? 'badge-rent' : 'badge-sale' %>">
              For <%= idListing.listingType %>
            </span>
          <% } %>
        </div>
      </div>
    </div>

    <!-- ── IMAGE ── -->
    <div class="col-12 col-lg-8 col-md-10 offset-lg-2 offset-md-1 px-3 px-md-0 mb-3">

      <div class="show-img-container">
        <% if(idListing.image && idListing.image.length > 1) { %>
          <div id="listingCarousel" class="carousel slide h-100" data-bs-ride="false">
            <div class="carousel-inner h-100">
              <% idListing.image.forEach((image, index) => { %>
                <div class="carousel-item h-100 <%= index === 0 ? 'active' : '' %>">
                  <img src="<%= image.url %>" class="show-img" alt="listing image <%= index + 1 %>">
                </div>
              <% }); %>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#listingCarousel" data-bs-slide="prev">
              <span class="carousel-control-prev-icon" aria-hidden="true"></span>
              <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#listingCarousel" data-bs-slide="next">
              <span class="carousel-control-next-icon" aria-hidden="true"></span>
              <span class="visually-hidden">Next</span>
            </button>
            <span class="gallery-counter" id="galleryCounter">1 / <%= idListing.image.length %></span>
          </div>

        <% } else if(idListing.image && idListing.image.length === 1) { %>
          <img src="<%= idListing.image[0].url %>" class="show-img" alt="listing image">

        <% } else { %>
          <img src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&q=80&w=1200"
            class="show-img" alt="placeholder">
        <% } %>
      </div>

      <!-- Thumbnail strip (only if multiple images) -->
      <% if(idListing.image && idListing.image.length > 1) { %>
        <div class="gallery-thumbs" id="galleryThumbs">
          <% idListing.image.forEach((image, index) => { %>
            <div class="gallery-thumb <%= index === 0 ? 'active' : '' %>" data-bs-target="#listingCarousel"
              data-bs-slide-to="<%= index %>">
              <img src="<%= image.url %>" alt="thumb <%= index + 1 %>">
            </div>
          <% }); %>
        </div>
      <% } %>
    </div><!-- /col image -->

    <!-- ── LISTING DETAILS ── -->
    <div class="col-12 col-lg-8 col-md-10 offset-lg-2 offset-md-1 px-3 px-md-0">

      <!-- Host info -->
      <a href="/profile/public/<%= idListing.owner ? idListing.owner._id : '' %>" class="host-card-link">
        <div class="listing-detail-card host-card d-flex align-items-center flex-wrap gap-3 mt-4 mb-3">
          <div class="host-avatar host-avatar-lg">
            <%= idListing.owner ? idListing.owner.username.charAt(0).toUpperCase() : 'U' %>
          </div>
          <div>
            <h5 class="mb-0 fw-semibold">
              Hosted by <%= idListing.owner ? idListing.owner.username : 'Unknown User' %>
            </h5>
            <span class="text-muted small">Joined recently</span>
          </div>
          <div class="ms-auto d-flex align-items-center gap-2">
            <% if(idListing.specifications && idListing.specifications.portfolioLink) { %>
              <div class="btn btn-outline-secondary host-portfolio-btn">
                <i class="fa-solid fa-link"></i> Portfolio
              </div>
            <% } %>
            <object><a href="/messages?receiverId=<%= idListing.owner ? idListing.owner._id : '' %>"
                class="btn btn-primary-custom host-msg-btn">
                Message Host
              </a></object>
          </div>
        </div>
      </a>

      <!-- Main Details Card (Price, Condition, Specs, Address) -->
      <div class="listing-detail-card mb-4">

        <!-- Price -->
        <div class="price-display price-block">
          <span class="price-symbol">&#8360;</span>
          <span class="price-amount"><%= idListing.price.toLocaleString('en-PK') %></span>
          <% if(idListing.listingType === 'Rent' && idListing.rentalPeriod && idListing.rentalPeriod !== 'N/A') { %>
            <span class="price-period">
              <% if(idListing.rentalPeriod === 'flat') { %>(Flat / Quoted Price)<% } else { %>/ <%= idListing.rentalPeriod %><% } %>
            </span>
          <% } %>
        </div>

        <!-- Condition -->
        <% if(idListing.conditionGrade && idListing.mainCategory !== 'Service') { %>
          <% var barWidth = idListing.conditionGrade * 10;
             var gradeColor = '#dc3545';
             if (idListing.conditionGrade >= 7) { gradeColor = '#28a745'; }
             else if (idListing.conditionGrade >= 4) { gradeColor = '#ffc107'; } %>
          <div class="mb-4">
            <span class="fw-semibold condition-label">Condition:</span>
            <span class="ms-1 condition-label"><%= idListing.conditionGrade %>/10</span>
            <div class="progress condition-bar">
              <div class="progress-bar" role="progressbar"
                data-bar-width="<%= barWidth %>"
                data-bar-color="<%= gradeColor %>">
              </div>
            </div>
            <script>
              (function () {
                var bar = document.currentScript.previousElementSibling.querySelector('.progress-bar');
                bar.style.width = bar.dataset.barWidth + '%';
                bar.style.backgroundColor = bar.dataset.barColor;
              })();
            </script>
          </div>
        <% } %>

        <!-- Specifications -->
        <% if(idListing.specifications) {
             const specs = idListing.specifications;
             const hasSpecs = specs.make || specs.model || specs.year || specs.area ||
                              specs.bedrooms != null || specs.bathrooms != null ||
                              specs.brand || specs.experience; %>
          <% if(hasSpecs) { %>
            <h6 class="fw-semibold mb-3 section-subheading">Specifications</h6>
            <div class="specs-grid mb-4">
              <% if(specs.make) { %><div class="spec-item"><span class="spec-label">Make</span><span class="spec-value spec-value-bold"><%= specs.make %></span></div><% } %>
              <% if(specs.model) { %><div class="spec-item"><span class="spec-label">Model</span><span class="spec-value spec-value-bold"><%= specs.model %></span></div><% } %>
              <% if(specs.year) { %><div class="spec-item"><span class="spec-label">Year</span><span class="spec-value spec-value-bold"><%= specs.year %></span></div><% } %>
              <% if(specs.area) { %><div class="spec-item"><span class="spec-label">Area</span><span class="spec-value spec-value-bold"><%= specs.area %></span></div><% } %>
              <% if(specs.bedrooms != null) { %><div class="spec-item"><span class="spec-label">Bedrooms</span><span class="spec-value spec-value-bold"><%= specs.bedrooms %></span></div><% } %>
              <% if(specs.bathrooms != null) { %><div class="spec-item"><span class="spec-label">Bathrooms</span><span class="spec-value spec-value-bold"><%= specs.bathrooms %></span></div><% } %>
              <% if(specs.brand) { %><div class="spec-item"><span class="spec-label">Brand</span><span class="spec-value spec-value-bold"><%= specs.brand %></span></div><% } %>
              <% if(specs.experience) { %><div class="spec-item"><span class="spec-label">Experience</span><span class="spec-value spec-value-bold"><%= specs.experience %></span></div><% } %>
              <% if(specs.serviceLocation) { %><div class="spec-item spec-item-full"><span class="spec-label"><i class="fa-solid fa-location-dot me-1" style="color:var(--primary)"></i>Service Area</span><span class="spec-value spec-value-bold"><%= specs.serviceLocation %></span></div><% } %>
            </div>
          <% } %>
        <% } %>

        <!-- Address -->
        <% if(idListing.address) { %>
          <div class="d-flex align-items-start gap-2 text-muted address-row">
            <i class="fa-solid fa-map-pin mt-1" style="color:var(--primary)"></i>
            <span><%= idListing.address %>, <%= idListing.city %>, <%= idListing.country %></span>
          </div>
        <% } %>

      </div>

      <!-- Description Card -->
      <div class="listing-detail-card mb-4">
        <h5 class="fw-semibold mb-3">About this listing</h5>
        <p class="description listing-description">
          <%= idListing.description %>
        </p>
      </div>

    </div><!-- /col details -->


    <!-- ── OWNER ACTIONS ── -->
    <% if(currUser && (currUser._id.equals(idListing.owner._id) || currUser.role === 'admin')) { %>
      <div class="col-12 col-lg-8 col-md-10 offset-lg-2 offset-md-1 px-3 px-md-0 mb-4 mt-2">
        <div class="d-flex gap-3 flex-wrap">
          <a href="/explore/<%= idListing._id %>/edit" class="btn btn-primary-custom">Edit Listing</a>
          <form method="post" action="/explore/<%= idListing._id %>?_method=DELETE" style="margin:0;">
            <button class="btn btn-outline-danger owner-actions-btn-delete">Delete</button>
          </form>
        </div>
      </div>
    <% } %>


    <!-- ── AI REVIEW SUMMARY ── -->
    <% if (idListing.reviewSummary) { %>
      <div class="col-12 col-lg-8 col-md-10 offset-lg-2 offset-md-1 px-3 px-md-0 mb-4">
        <div class="listing-detail-card ai-summary-card ai-summary-card-bordered">
          <div class="ai-summary-icon"><i class="fa-solid fa-wand-magic-sparkles"></i></div>
          <div>
            <h5 class="fw-semibold mb-2">AI Review Summary</h5>
            <p class="mb-0 text-muted ai-summary-text">
              <%= idListing.reviewSummary %>
            </p>
            <p class="mt-2 mb-0 ai-summary-note">
              Auto-generated based on user feedback.
            </p>
          </div>
        </div>
      </div>
    <% } %>


    <!-- ── MAP ── -->
    <div class="col-12 col-lg-8 col-md-10 offset-lg-2 offset-md-1 px-3 px-md-0 mb-4">
      <div class="listing-detail-card">
        <h5 class="fw-semibold mb-2">Where you'll be</h5>
        <p class="text-muted mb-3 map-address-text">
          <% if(idListing.address) { %><%= idListing.address %>, <% } %><%= idListing.city %>, <%= idListing.country %>
        </p>
        <div class="map-container map-wrapper">
          <div id="map"></div>
        </div>
      </div>
    </div>


    <!-- ── REVIEWS ── -->
    <div class="col-12 col-lg-8 col-md-10 offset-lg-2 offset-md-1 px-3 px-md-0 mb-4">
      <div class="listing-detail-card">
        <h5 class="fw-semibold mb-4">Reviews</h5>

        <% if (idListing.reviews && idListing.reviews.length > 0) { %>
          <div class="row">
            <% for(let review of idListing.reviews) { %>
              <div class="col-md-6 mb-3">
                <div class="card p-3 h-100 review-card">
                  <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="review-avatar">
                      <%= review.author ? review.author.username.charAt(0).toUpperCase() : 'A' %>
                    </div>
                    <h6 class="card-title mb-0 fw-semibold">
                      <%= review.author ? review.author.username : 'Anonymous User' %>
                    </h6>
                  </div>
                  <p class="card-text starability-result mb-2" data-rating="<%= review.rating %>"></p>
                  <p class="card-text review-comment">
                    <%= review.comment %>
                  </p>
                  <form method="POST" action="/explore/<%= idListing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mt-auto pt-2">
                    <% if(currUser && (currUser._id.equals(idListing.owner._id) || (review.author && currUser._id.equals(review.author._id)) || currUser.role === 'admin')) { %>
                      <button class="btn btn-sm btn-outline-danger review-delete-btn">Delete</button>
                    <% } %>
                  </form>
                </div>
              </div>
            <% } %>
          </div>
        <% } else { %>
          <p class="text-muted mb-0">No reviews yet. Be the first to leave one!</p>
        <% } %>
      </div>
    </div>


    <!-- ── LEAVE A REVIEW ── -->
    <% if(currUser) { %>
      <div class="col-12 col-lg-8 col-md-10 offset-lg-2 offset-md-1 px-3 px-md-0 mb-5">
        <div class="listing-detail-card">
          <h5 class="fw-semibold mb-3">Leave a Review</h5>
          <form method="POST" action="/explore/<%= idListing._id %>/reviews" novalidate class="needs-validation">
            <div class="mb-3">
              <fieldset class="starability-growRotate">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
              </fieldset>
            </div>
            <div class="mb-3">
              <label for="comment" class="form-label text-muted review-label">Comment</label>
              <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control review-textarea"
                required maxlength="450" placeholder="Max 450 characters..."></textarea>
              <div class="invalid-feedback">Please add some comment for review!</div>
            </div>
            <button class="btn btn-primary-custom review-submit-btn">Submit</button>
          </form>
        </div>
      </div>
    <% } %>

  </div><!-- /row -->

  <br />
  <script src="/js/map.js"></script>

  <!-- Thumbnail sync -->
  <script>
    (function () {
      var carousel = document.getElementById('listingCarousel');
      if (!carousel) return;
      var thumbs = document.querySelectorAll('.gallery-thumb');
      var counter = document.getElementById('galleryCounter');
      var total = thumbs.length;

      thumbs.forEach(function (thumb) {
        thumb.addEventListener('click', function () {
          bootstrap.Carousel.getOrCreateInstance(carousel).to(parseInt(thumb.dataset.bsSlideTo));
        });
      });

      carousel.addEventListener('slid.bs.carousel', function (e) {
        thumbs.forEach(function (t) { t.classList.remove('active'); });
        if (thumbs[e.to]) thumbs[e.to].classList.add('active');
        if (counter) counter.textContent = (e.to + 1) + ' / ' + total;
        if (thumbs[e.to]) thumbs[e.to].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      });
    })();
  </script>