<% layout('/layouts/boilerplate') %>
<% locals.showBackBtn = true; %>

  <style>
    .legal-page {
      max-width: 780px;
      margin: 0 auto;
      padding: 2.5rem 1rem 3rem;
    }

    .legal-page h1 {
      font-size: 2.2rem;
      font-weight: 800;
      color: var(--text-dark);
      margin-bottom: 0.4rem;
    }

    .legal-page .legal-meta {
      color: var(--text-muted);
      font-size: 0.9rem;
      margin-bottom: 2.5rem;
    }

    .legal-divider {
      border: none;
      border-top: 1px solid var(--bg-tertiary);
      margin: 2rem 0;
    }

    .legal-nav {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 2.5rem;
    }

    .legal-nav a {
      background: var(--bg-secondary);
      color: var(--text-dark);
      font-size: 0.85rem;
      font-weight: 500;
      padding: 0.35rem 0.9rem;
      border-radius: 20px;
      text-decoration: none;
      transition: background var(--transition-fast), color var(--transition-fast);
    }

    .legal-nav a:hover,
    .legal-nav a.active {
      background: var(--primary);
      color: #fff;
    }

    .sitemap-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 2rem;
    }

    .sitemap-group h2 {
      font-size: 1rem;
      font-weight: 700;
      color: var(--text-dark);
      border-left: 3px solid var(--primary);
      padding-left: 0.65rem;
      margin-bottom: 0.85rem;
    }

    .sitemap-group ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .sitemap-group ul li {
      margin-bottom: 0.6rem;
    }

    .sitemap-group ul li a {
      color: var(--text-muted);
      font-size: 0.92rem;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.45rem;
      transition: color var(--transition-fast);
    }

    .sitemap-group ul li a i {
      font-size: 0.8rem;
      color: var(--text-light);
    }

    .sitemap-group ul li a:hover {
      color: var(--primary);
    }
  </style>

  <div class="legal-page">
    <h1>Sitemap</h1>
    <p class="legal-meta">A complete map of all pages on Rentlyst</p>


    <div class="sitemap-grid">

      <div class="sitemap-group">
        <h2>Main</h2>
        <ul>
          <li><a href="/"><i class="fa-solid fa-house"></i> Home</a></li>
          <li><a href="/explore"><i class="fa-solid fa-compass"></i> Explore Listings</a></li>
          <li><a href="/explore/search"><i class="fa-solid fa-magnifying-glass"></i> Search</a></li>
          <li><a href="/explore/new"><i class="fa-solid fa-plus"></i> Add New Listing</a></li>
        </ul>
      </div>

      <div class="sitemap-group">
        <h2>Account</h2>
        <ul>
          <li><a href="/login"><i class="fa-solid fa-right-to-bracket"></i> Log In</a></li>
          <li><a href="/signup"><i class="fa-solid fa-user-plus"></i> Sign Up</a></li>
          <li><a href="/profile"><i class="fa-regular fa-user"></i> My Profile</a></li>
          <li><a href="/logout"><i class="fa-solid fa-arrow-right-from-bracket"></i> Log Out</a></li>
        </ul>
      </div>

      <div class="sitemap-group">
        <h2>Platform</h2>
        <ul>
          <li><a href="/messages"><i class="fa-regular fa-comment-dots"></i> Messages</a></li>
          <li><a href="/agent"><i class="fa-solid fa-robot"></i> Rentlyst Agent (AI)</a></li>
        </ul>
      </div>

      <div class="sitemap-group">
        <h2>Legal & Support</h2>
        <ul>
          <li><a href="/terms"><i class="fa-solid fa-file-lines"></i> Terms of Service</a></li>
          <li><a href="/privacy"><i class="fa-solid fa-shield-halved"></i> Privacy Policy</a></li>
          <li><a href="/sitemap"><i class="fa-solid fa-map"></i> Sitemap</a></li>
          <li><a href="/help"><i class="fa-solid fa-circle-question"></i> Help Center</a></li>
        </ul>
      </div>

    </div>
  </div>