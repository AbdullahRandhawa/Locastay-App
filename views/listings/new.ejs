<% layout("/layouts/boilerplate") %>
  <link rel="stylesheet" href="/css/form.css" />

  <body>
    <div class="row">
      <div class="col-10 col-lg-8 col-md-10 offset-1 offset-lg-2 offset-md-1">

        <form method="POST" action="/listings" class="needs-validation" novalidate enctype="multipart/form-data">

          <!-- ==================== STEP 1: CATEGORY ==================== -->
          <div id="step1">
            <h3 class="fw-semibold text-center mt-3 mb-2">Create New Listing</h3>
            <p class="text-muted text-center mb-5">Choose a category and listing type to get started</p>

            <!-- Main Category Cards -->
            <label class="form-label fw-semibold mb-3 text-dark">Category</label>
            <div class="row g-3 mb-5 pb-2">
              <% const catIcons={ Item: 'fa-box-open' , Vehicle: 'fa-car' , Property: 'fa-house' , Service: 'fa-wrench'
                }; %>
                <% Object.keys(CATEGORIES).forEach(cat=> { %>
                  <div class="col-6 col-md-3">
                    <input type="radio" name="listing[mainCategory]" id="cat-<%= cat %>" value="<%= cat %>"
                      class="d-none cat-radio" required>
                    <label for="cat-<%= cat %>" class="cat-card">
                      <i class="fa-solid <%= catIcons[cat] || 'fa-tag' %>"></i>
                      <span>
                        <%= cat %>
                      </span>
                    </label>
                  </div>
                  <% }) %>
            </div>

            <!-- Listing Type Cards -->
            <div id="listingTypeSectionWrapper">
              <label class="form-label fw-semibold mb-3 text-dark">Listing Type</label>
              <div class="row g-3 mb-5 pb-3">
                <div class="col-6">
                  <input type="radio" name="listing[listingType]" id="type-Sale" value="Sale" class="d-none type-radio"
                    checked required>
                  <label for="type-Sale" class="cat-card">
                    <i class="fa-solid fa-tag"></i>
                    <span>For Sale</span>
                  </label>
                </div>
                <div class="col-6">
                  <input type="radio" name="listing[listingType]" id="type-Rent" value="Rent" class="d-none type-radio">
                  <label for="type-Rent" class="cat-card">
                    <i class="fa-solid fa-clock"></i>
                    <span>For Rent</span>
                  </label>
                </div>
              </div>
            </div>

            <button type="button" id="nextBtn" class="btn btn-primary-custom w-100 fs-5 py-3 shadow-sm" disabled>Next
              &rarr;</button>
          </div>

          <!-- ==================== STEP 2: DETAILS ==================== -->
          <div id="step2" class="d-none">
            <h3 class="fw-semibold text-center mt-3 mb-5">Listing Details</h3>
            <div class="d-flex justify-content-start mb-4 pb-2">
              <button type="button" id="backBtn" class="btn btn-outline-dark fw-semibold"
                style="border-radius: var(--radius-sm); padding: 0.6rem 1.8rem;">&larr; Back to Category</button>
            </div>

            <!-- Title -->
            <div class="mb-5">
              <label for="title" class="form-label fw-semibold">Title</label>
              <input type="text" name="listing[title]" placeholder="Enter a catchy name..."
                class="form-control form-input" id="title" maxlength="100" required />
              <div class="valid-feedback">Title looks good!</div>
            </div>

            <!-- Image Upload -->
            <div class="mb-5">
              <label for="image" class="form-label fw-semibold">Upload Images</label>
              <input type="file" name="listing[image]" class="form-control form-input form-input-file" id="image"
                multiple />
            </div>

            <!-- Sub Category + Rental Period -->
            <div class="row mb-5">
              <div class="col-md-6 mb-5 mb-md-0">
                <label for="subCategory" class="form-label fw-semibold">Sub Category</label>
                <div class="select-wrapper">
                  <select name="listing[subCategory]" id="subCategory" class="form-select form-input custom-select"
                    required>
                    <option value="" disabled selected>Select sub category...</option>
                  </select>
                </div>
                <div class="invalid-feedback">Please select a sub category</div>
              </div>
              <div class="col-md-6 d-none" id="portfolioGroup">
                <label for="portfolioLink" class="form-label fw-semibold">Portfolio / Website Link</label>
                <input type="url" name="listing[specifications][portfolioLink]" placeholder="e.g. https://mywork.com"
                  class="form-control form-input" id="portfolioLink" disabled>
              </div>
            </div>

            <!-- Category-Specific Specs -->
            <div class="specs-group d-none" id="specsVehicle">
              <label class="form-label fw-semibold mb-3">Vehicle Details</label>
              <div class="row mb-5">
                <div class="col-md-4 mb-4 mb-md-0">
                  <input type="text" name="listing[specifications][make]" placeholder="Make (e.g. Toyota)"
                    class="form-control form-input" disabled>
                </div>
                <div class="col-md-4 mb-4 mb-md-0">
                  <input type="text" name="listing[specifications][model]" placeholder="Model (e.g. Corolla)"
                    class="form-control form-input" disabled>
                </div>
                <div class="col-md-4">
                  <input type="number" name="listing[specifications][year]" placeholder="Year (e.g. 2022)"
                    class="form-control form-input" min="1900" max="2026" disabled>
                </div>
              </div>
            </div>
            <div class="specs-group d-none" id="specsProperty">
              <label class="form-label fw-semibold mb-3">Property Details</label>
              <div class="row mb-5">
                <div class="col-md-4 mb-4 mb-md-0">
                  <input type="text" name="listing[specifications][area]" placeholder="Area (e.g. 5 Marla)"
                    class="form-control form-input" disabled>
                </div>
                <div class="col-md-4 mb-4 mb-md-0">
                  <input type="number" name="listing[specifications][bedrooms]" placeholder="Bedrooms"
                    class="form-control form-input" min="0" disabled>
                </div>
                <div class="col-md-4">
                  <input type="number" name="listing[specifications][bathrooms]" placeholder="Bathrooms"
                    class="form-control form-input" min="0" disabled>
                </div>
              </div>
            </div>
            <div class="specs-group d-none" id="specsItem">
              <label class="form-label fw-semibold mb-3">Item Details</label>
              <div class="row mb-5">
                <div class="col-md-6 mb-4 mb-md-0">
                  <input type="text" name="listing[specifications][brand]" placeholder="Brand (e.g. Samsung)"
                    class="form-control form-input" disabled>
                </div>
                <div class="col-md-6">
                  <input type="text" name="listing[specifications][model]" placeholder="Model (e.g. Galaxy S24)"
                    class="form-control form-input" disabled>
                </div>
              </div>
            </div>
            <div class="specs-group d-none" id="specsService">
              <label class="form-label fw-semibold  mb-3">Service Details</label>
              <div class="row mb-5">
                <div class="col-md-6 mb-4 mb-md-0">
                  <input type="text" name="listing[specifications][experience]" placeholder="Experience (e.g. 5 years)"
                    class="form-control form-input" disabled>
                </div>
                <div class="col-md-6">
                  <select name="listing[specifications][serviceLocation]" class="form-select form-input custom-select"
                    disabled>
                    <option value="" disabled selected>Service Location...</option>
                    <option value="Online">Remote / Online</option>
                    <option value="On-site">On-site</option>
                    <option value="On-site & Online">On-site & Online</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- Price + Condition -->
            <div class="row mb-5">
              <div class="col-md-6 mb-5 mb-md-0">
                <label for="price" class="form-label fw-semibold">Price</label>
                <div class="input-group">
                  <span class="input-group-text ig-custom">&#8360;</span>
                  <input type="number" name="listing[price]" placeholder="0"
                    class="form-control form-input border-start-0" id="price" min="0" required />
                </div>
                <div class="invalid-feedback">Price should be valid!</div>
              </div>
              <div class="col-md-6 mb-5 mb-md-0 d-none" id="rentalPeriodGroup">
                <label for="rentalPeriod" id="rentalPeriodLabel" class="form-label fw-semibold">Rental Period</label>
                <div class="select-wrapper">
                  <select name="listing[rentalPeriod]" id="rentalPeriod" class="form-select form-input custom-select">
                    <option value="N/A" selected>Not Applicable</option>
                    <option value="hour">Per Hour</option>
                    <option value="day">Per Day</option>
                    <option value="week">Per Week</option>
                    <option value="month">Per Month</option>
                    <option value="flat">Flat / Quoted Price</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- Condition -->
            <div class="row mb-5" id="conditionGroupWrapper">
              <div class="col-md-6" id="conditionGroup">
                <label for="conditionGrade" class="form-label fw-semibold">Condition: <span
                    id="conditionValue">—</span>/10</label>
                <input type="range" id="conditionGrade" class="form-range mt-3" min="1" max="10" value="5">
                <input type="hidden" name="listing[conditionGrade]" id="conditionGradeHidden">
                <div class="d-flex justify-content-between">
                  <small class="fw-bold text-muted">Poor</small>
                  <small class="fw-bold text-muted">Excellent</small>
                </div>
                <small class="text-muted">Move the slider to set a condition rating</small>
              </div>
            </div>

            <!-- Address -->
            <div class="mb-5">
              <label for="address" class="form-label fw-semibold">Address</label>
              <input type="text" name="listing[address]" placeholder="e.g. Street 5, Block B..."
                class="form-control form-input" id="address" required />
              <div class="invalid-feedback">Address is required!</div>
            </div>

            <!-- City + Country -->
            <div class="row mb-5">
              <div class="col-md-6 mb-5 mb-md-0">
                <label for="city" class="form-label fw-semibold">City</label>
                <input type="text" name="listing[city]" placeholder="e.g. Lahore..." class="form-control form-input"
                  id="city" required />
                <div class="invalid-feedback">City is required!</div>
              </div>
              <div class="col-md-6">
                <label for="countryy" class="form-label fw-semibold">Country</label>
                <input type="text" name="listing[country]" placeholder="e.g. Pakistan..."
                  class="form-control form-input" id="countryy" required />
                <div class="invalid-feedback">Country name should be valid!</div>
              </div>
            </div>

            <!-- Description -->
            <div class="mb-5 pb-3">
              <label for="description" class="form-label fw-semibold">Description</label>
              <textarea name="listing[description]" class="form-control form-input" id="description" rows="5"
                required></textarea>
              <div class="invalid-feedback">Write a short description</div>
            </div>

            <button class="btn btn-primary-custom w-100 fs-4 mb-5 py-3 shadow-sm">Create Listing</button>
          </div>

        </form>
      </div>
    </div>
    <script id="categoriesData" type="application/json"><%- JSON.stringify(CATEGORIES) %></script>
    <script>
      const CATEGORIES = JSON.parse(document.getElementById('categoriesData').textContent);

      const step1 = document.getElementById('step1');
      const step2 = document.getElementById('step2');
      const nextBtn = document.getElementById('nextBtn');
      const backBtn = document.getElementById('backBtn');
      const subCatSelect = document.getElementById('subCategory');
      const rentalGroup = document.getElementById('rentalPeriodGroup');
      const rentalSelect = document.getElementById('rentalPeriod');
      const condSlider = document.getElementById('conditionGrade');
      const condValue = document.getElementById('conditionValue');

      let selectedCat = null;

      // Category selection — enable Next button and trigger form logic
      document.querySelectorAll('.cat-radio').forEach(r => {
        r.addEventListener('change', () => {
          selectedCat = r.value;
          nextBtn.disabled = false;
          updateDynamicFields(selectedCat);
        });
      });

      // Listing type toggle — rental period
      document.querySelectorAll('.type-radio').forEach(r => {
        r.addEventListener('change', () => {
          if (r.value === 'Rent') { rentalGroup.classList.remove('d-none'); rentalSelect.value = 'month'; }
          else { rentalGroup.classList.add('d-none'); rentalSelect.value = 'N/A'; }
        });
      });

      function updateDynamicFields(cat) {
        const listingTypeSection = document.getElementById('listingTypeSectionWrapper');
        const conditionSection = document.getElementById('conditionGroupWrapper');
        const rentalLabel = document.getElementById('rentalPeriodLabel');
        const portfolioGroup = document.getElementById('portfolioGroup');
        const portfolioLink = document.getElementById('portfolioLink');

        if (cat === 'Service') {
          if (listingTypeSection) {
            listingTypeSection.classList.add('d-none');
          }
          if (conditionSection) conditionSection.classList.add('d-none');
          if (rentalLabel) rentalLabel.textContent = 'Pricing Model';
          document.getElementById('type-Rent').click(); // Force the type-Rent radio

          if (portfolioGroup) portfolioGroup.classList.remove('d-none');
          if (portfolioLink) portfolioLink.disabled = false;
        } else {
          if (listingTypeSection) {
            listingTypeSection.classList.remove('d-none');
          }
          if (conditionSection) conditionSection.classList.remove('d-none');
          if (rentalLabel) rentalLabel.textContent = 'Rental Period';

          if (portfolioGroup) portfolioGroup.classList.add('d-none');
          if (portfolioLink) portfolioLink.disabled = true;
        }
      }

      // Step navigation
      nextBtn.addEventListener('click', () => {
        step1.classList.add('d-none');
        step2.classList.remove('d-none');
        // Populate subcategories
        const subs = CATEGORIES[selectedCat] || [];
        subCatSelect.innerHTML = '<option value="" disabled selected>Select sub category...</option>';
        subs.forEach(sub => { const o = document.createElement('option'); o.value = sub; o.textContent = sub; subCatSelect.appendChild(o); });
        updateSpecs(selectedCat);
      });

      backBtn.addEventListener('click', () => { step2.classList.add('d-none'); step1.classList.remove('d-none'); });

      // Condition slider — only submits if user moves it
      condSlider.addEventListener('input', () => {
        condValue.textContent = condSlider.value;
        document.getElementById('conditionGradeHidden').value = condSlider.value;
      });

      // Specs: disable hidden, enable visible
      function updateSpecs(cat) {
        document.querySelectorAll('.specs-group').forEach(g => { g.classList.add('d-none'); g.querySelectorAll('input, select').forEach(i => i.disabled = true); });
        const m = { 'Vehicle': 'specsVehicle', 'Property': 'specsProperty', 'Item': 'specsItem', 'Service': 'specsService' };
        if (m[cat]) { const el = document.getElementById(m[cat]); el.classList.remove('d-none'); el.querySelectorAll('input, select').forEach(i => i.disabled = false); }
      }
    </script>