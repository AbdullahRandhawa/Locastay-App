<% layout("/layouts/boilerplate") %>

    <body class="container-fluid">
        <br>
        <p> All searches for : <b>
                <%=q%>
            </b>
        </p>
        <br>
        <br>
        <% if(allListings.length===0){ %>
            <h1>No listings found matching your Search!</h1>
            <%} %>

                <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 ">
                    <% for(let listing of allListings){ %>
                        <a href="/listings/<%= listing._id %>" class="listing-link">
                            <div class="card listing-card card-clicked">
                                <img src="<%= listing.image && listing.image.length > 0 ? listing.image[0].url : 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&q=80&w=800' %>"
                                    class="card-img-top" style="height: 20rem;" alt="listing-image">
                                <div class="card-body">
                                    <p class="card-text"><b>
                                            <%= listing.title %>
                                        </b><br>
                                        &#8360; <%= listing.price.toLocaleString('en-PK') %>
                                            <% if(listing.listingType==='Rent' && listing.rentalPeriod &&
                                                listing.rentalPeriod !=='N/A' ) { %>
                                                / <%= listing.rentalPeriod %>
                                                    <% } %>
                                    </p>
                                </div>
                            </div>

                        </a>
                        <%} %>

                </div>

    </body>