<% layout("/layouts/boilerplate") %>
  <div id="listing-data" data-listing="<%= JSON.stringify(idListing) %>" style="display:none"></div>
  <script>
    window.mapToken = "<%= process.env.MAP_TOKEN %>";
    window.listing = JSON.parse(document.getElementById('listing-data').dataset.listing);
  </script>

  <body>
    <script>
      window.onload = function () {
        window.scrollTo(0, 0);
      };
    </script>
    <div class="row">
      <div class="col-10 col-lg-8 col-md-10  offset-1 offset-lg-2 offset-md-1 ">
        <br />
        <div class="show-header">
          <h3>
            <%= idListing.title %>
          </h3>
          <p class="text-muted">
            <%= idListing.city %>, <%= idListing.country %>
          </p>
          <!-- Category & Type Badges -->
          <div class="d-flex flex-wrap gap-2 mb-2">
            <% if(idListing.mainCategory) { %>
              <span class="badge bg-primary">
                <%= idListing.mainCategory %>
              </span>
              <% } %>
                <% if(idListing.subCategory) { %>
                  <span class="badge bg-secondary">
                    <%= idListing.subCategory %>
                  </span>
                  <% } %>
                    <% if(idListing.listingType) { %>
                      <span class="badge bg-<%= idListing.listingType === 'Rent' ? 'warning text-dark' : 'success' %>">
                        For <%= idListing.listingType %>
                      </span>
                      <% } %>
          </div>
        </div>
      </div>

      <div class="col-12 col-lg-8 col-md-10 offset-lg-2 offset-md-1">
        <div class="show-img-container position-relative">
          <% if(idListing.image && idListing.image.length> 1) { %>
            <div id="listingCarousel" class="carousel slide h-100" data-bs-ride="carousel">
              <div class="carousel-inner h-100">
                <% idListing.image.forEach((image, index)=> { %>
                  <div class="carousel-item h-100 <%= index === 0 ? 'active' : '' %>">
                    <img src="<%= image.url %>" class="d-block w-100 show-img" alt="listing-image">
                  </div>
                  <% }); %>
              </div>
              <button class="carousel-control-prev" type="button" data-bs-target="#listingCarousel"
                data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
              </button>
              <button class="carousel-control-next" type="button" data-bs-target="#listingCarousel"
                data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
              </button>
            </div>
            <% } else if(idListing.image && idListing.image.length===1) { %>
              <img src="<%= idListing.image[0].url %>" class="d-block w-100 show-img" alt="listing-image">
              <% } else { %>
                <img src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&q=80&w=1200"
                  class="d-block w-100 show-img" alt="placeholder">
                <% } %>
        </div>

        <div class="host-info">
          <div class="host-avatar">
            <%= idListing.owner ? idListing.owner.username.charAt(0).toUpperCase() : 'U' %>
          </div>
          <div>
            <h5 class="mb-0 fw-semibold">Hosted by <%= idListing.owner ? idListing.owner.username : 'Unknown User' %>
            </h5>
            <span class="text-muted small">Superhost &middot; Joined recently</span>
          </div>
          <a href="/messages?receiverId=<%= idListing.owner ? idListing.owner._id : '' %>"
            class="btn btn-primary-custom ms-auto" style="padding: 0.5rem 1rem;">
            Message Host
          </a>
        </div>

        <div class="row mb-4">
          <div class="col-md-8">
            <h5 class="fw-semibold mb-3">About this listing</h5>
            <p class="description">
              <%= idListing.description %>
            </p>

            <!-- Dynamic Price Display -->
            <div class="mt-4 p-4 border rounded" style="background-color: var(--bg-secondary);">
              <h5 class="fw-semibold mb-1">&#8360; <%= idListing.price.toLocaleString('en-PK') %>
                  <% if(idListing.listingType==='Rent' && idListing.rentalPeriod && idListing.rentalPeriod !=='N/A' ) {
                    %>
                    <span class="fw-normal text-muted fs-6">/ <%= idListing.rentalPeriod %></span>
                    <% } %>
              </h5>
            </div>

            <!-- Condition Grade -->
            <% if(idListing.conditionGrade) { %>
              <div class="mt-3">
                <span class="fw-semibold">Condition:</span>
                <span class="ms-1">
                  <%= idListing.conditionGrade %>/10
                </span>
                <% var barWidth=idListing.conditionGrade * 10; var gradeColor='#dc3545'; if (idListing.conditionGrade >= 7) { gradeColor = '#28a745'; } else if (idListing.conditionGrade >= 4) { gradeColor = '#ffc107'; } %>
                  <div class="progress mt-1" style="height: 8px;">
                    <div class="progress-bar" role="progressbar"
                      data-bar-width="<%= barWidth %>"
                      data-bar-color="<%= gradeColor %>">
                    </div>
                  </div>
                  <script>
                    (function(){
                      var bar = document.currentScript.previousElementSibling.querySelector('.progress-bar');
                      bar.style.width = bar.dataset.barWidth + '%';
                      bar.style.backgroundColor = bar.dataset.barColor;
                    })();
                  </script>
              </div>
              <% } %>

                <!-- Specifications -->
                <% if(idListing.specifications) { %>
                  <% const specs=idListing.specifications; %>
                    <% const hasSpecs=specs.make || specs.model || specs.year || specs.area || specs.bedrooms ||
                      specs.bathrooms || specs.brand || specs.experience; %>
                      <% if(hasSpecs) { %>
                        <div class="mt-4">
                          <h6 class="fw-semibold mb-2">Specifications</h6>
                          <div class="row g-2">
                            <% if(specs.make) { %>
                              <div class="col-auto"><span class="badge bg-light text-dark border px-3 py-2">Make: <%=
                                    specs.make %></span></div>
                              <% } %>
                                <% if(specs.model) { %>
                                  <div class="col-auto"><span class="badge bg-light text-dark border px-3 py-2">Model:
                                      <%= specs.model %>
                                    </span></div>
                                  <% } %>
                                    <% if(specs.year) { %>
                                      <div class="col-auto"><span
                                          class="badge bg-light text-dark border px-3 py-2">Year: <%= specs.year %>
                                        </span></div>
                                      <% } %>
                                        <% if(specs.area) { %>
                                          <div class="col-auto"><span
                                              class="badge bg-light text-dark border px-3 py-2">Area: <%= specs.area %>
                                            </span></div>
                                          <% } %>
                                            <% if(specs.bedrooms !=null) { %>
                                              <div class="col-auto"><span
                                                  class="badge bg-light text-dark border px-3 py-2">Bedrooms: <%=
                                                    specs.bedrooms %></span></div>
                                              <% } %>
                                                <% if(specs.bathrooms !=null) { %>
                                                  <div class="col-auto"><span
                                                      class="badge bg-light text-dark border px-3 py-2">Bathrooms: <%=
                                                        specs.bathrooms %></span></div>
                                                  <% } %>
                                                    <% if(specs.brand) { %>
                                                      <div class="col-auto"><span
                                                          class="badge bg-light text-dark border px-3 py-2">Brand: <%=
                                                            specs.brand %></span></div>
                                                      <% } %>
                                                        <% if(specs.experience) { %>
                                                          <div class="col-auto"><span
                                                              class="badge bg-light text-dark border px-3 py-2">Experience:
                                                              <%= specs.experience %>
                                                            </span></div>
                                                          <% } %>
                          </div>
                        </div>
                        <% } %>
                          <% } %>

                            <!-- Address -->
                            <% if(idListing.address) { %>
                              <div class="mt-3">
                                <span class="fw-semibold">Address:</span>
                                <span class="text-muted">
                                  <%= idListing.address %>
                                </span>
                              </div>
                              <% } %>

          </div>
        </div>
      </div>
      <% if(currUser && currUser._id.equals(idListing.owner._id)) { %>
        <div class="col-10 col-lg-8 col-md-10  offset-1 offset-lg-2 offset-md-1">
          <div class="row">
            <div class="col-3">
              <a href="/listings/<%= idListing._id %>/edit" class="btn btn-primary-custom">Edit Listing</a>
            </div>
            <div class="col-auto">
              <form method="post" action="/listings/<%= idListing._id %>?_method=DELETE">
                <button class="btn btn-outline-danger"
                  style="border-radius: var(--radius-sm); padding: 0.75rem 1.5rem; font-weight: 600;">Delete</button>
              </form>
            </div>
          </div>
          <br>
          <hr class="my-5">
        </div>
        <% }%>

          <div class="col-10 col-lg-8 col-md-10  offset-lg-2 offset-md-1">


            <%# ── AI REVIEW SUMMARY CARD ── %>
              <% if (idListing.reviewSummary) { %>
                <div class="row mb-5">
                  <div class="col-12">
                    <div class="card p-2 border-secondary" style="background-color: var(--bg-secondary);">
                      <div class="card-body">
                        <h5 class="card-title d-flex align-items-center gap-2">
                          AI Review Summary
                        </h5>
                        <p class="card-text mt-3">
                          <%= idListing.reviewSummary %>
                        </p>
                        <p class="card-text text-muted" style="font-size: 0.8rem; margin-top: 1rem; margin-bottom: 0;">
                          Auto-generated based on the feedback.
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
                <% } %>

                  <h4 class="fw-semibold mb-4">Reviews</h4>
                  <br>

                  <div class="row">
                    <% for(review of idListing.reviews) {%>
                      <div class="col-md-6 mb-3">
                        <div class="card p-2">
                          <div class="card-body">
                            <h5 class="card-title">
                              <%= review.author.username %>
                            </h5>
                            <p class="card-text starability-result" data-rating="<%= review.rating %>">
                            </p>
                            <p class="card-text">
                              <%= review.comment %>
                            </p>

                            <form method="POST"
                              action="/listings/<%= idListing._id %>/reviews/<%= review._id %>?_method=DELETE">
                              <% if(currUser && (currUser._id.equals(idListing.owner._id) ||
                                currUser._id.equals(review.author._id))) { %>
                                <button class="btn btn-sm btn-dark">Delete</button>
                                <% } %>
                            </form>

                          </div>
                        </div>
                      </div>
                      <% } %>
                  </div>
          </div>


          <% if(currUser) { %>
            <div class="col-10 col-lg-8 col-md-10  offset-1 offset-lg-2 offset-md-1">
              <hr class="my-5">
              <h3>Leave a Review</h3>
              <form method="POST" action="/listings/<%= idListing._id %>/reviews" novalidate class="needs-validation">
                <div class="mb-3 mt-3">
                  <fieldset class="starability-growRotate">
                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked
                      aria-label="No rating." />
                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                    <label for="first-rate1" title="Terrible">1 star</label>
                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                    <label for="first-rate2" title="Not good">2 stars</label>
                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                    <label for="first-rate3" title="Average">3 stars</label>
                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                    <label for="first-rate4" title="Very good">4 stars</label>
                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                    <label for="first-rate5" title="Amazing">5 stars</label>
                  </fieldset>
                </div>

                <div class="mb-3 mt-3">
                  <label for="comment" class="form-label">Comment</label>
                  <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control"
                    required></textarea>
                  <div class="invalid-feedback">Please add some comment for review!</div>
                </div>
                <button class="btn btn-outline-dark">Submit</button>
              </form>
              <br>

            </div>
            <% } %>
              <div class="col-10 col-lg-8 col-md-10 offset-lg-2 offset-md-1 mb-5">
                <hr class="my-5">
                <h4 class="fw-semibold mb-4">Where you'll be</h4>
                <p class="text-muted">
                  <% if(idListing.address) { %>
                    <%= idListing.address %>, <% } %>
                        <%= idListing.city %>, <%= idListing.country %>
                </p>
                <div class="map-container">
                  <div id="map"></div>
                </div>
              </div>
    </div>
    </div>
    <br />
    <script src="/js/map.js">  </script>
  </body>