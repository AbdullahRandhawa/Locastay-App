<% layout("/layouts/boilerplate") %>
  <style>
    /* Make the page body a locked flex column so the iframe fills all space below the navbar */
    html, body {
      height: 100% !important;
      overflow: hidden !important;
      margin: 0 !important;
      padding: 0 !important;
    }

    body {
      display: flex !important;
      flex-direction: column !important;
    }

    /* Remove Bootstrap mb-4 and reset the container so it fills remaining height */
    .container.flex-grow-1 {
      margin: 0 !important;
      padding: 0 !important;
      max-width: 100% !important;
      flex: 1 1 0 !important;
      min-height: 0 !important;
      display: flex !important;
      flex-direction: column !important;
      overflow: hidden !important;
    }

    /* Hide the flash injected elements */
    .container.flex-grow-1>br,
    .container.flex-grow-1>.row {
      display: none !important;
    }

    .messenger-iframe {
      width: 100%;
      flex: 1 1 0;
      min-height: 0;
      border: none;
      display: block;
    }

    footer {
      display: none !important;
    }
  </style>

  <iframe
    src="https://nocapchat.onrender.com/?fbToken=<%= fbToken %><%= receiverId ? '&receiverId=' + receiverId : '' %>"
    class="messenger-iframe" title="Rentlyst Messenger" allow="microphone; camera"></iframe>