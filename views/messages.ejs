<% layout("/layouts/boilerplate") %>
  <style>
    body {
      overflow: hidden !important;
    }

    .container.flex-grow-1.my-4 {
      margin: 0 !important;
      padding: 0 !important;
      max-width: 100% !important;
      height: calc(100vh - 67px) !important;
    }

    .messenger-iframe {
      width: 100vw;
      height: calc(100vh - 67px);
      border: none;
      display: block;
    }

    footer {
      display: none !important;
    }
  </style>

  <iframe
    src="https://nocapchat.onrender.com/?fbToken=<%= fbToken %><%= receiverId ? '&receiverId=' + receiverId : '' %>"
    class="messenger-iframe" title="Rentlyst Messenger" allow="microphone; camera"></iframe>