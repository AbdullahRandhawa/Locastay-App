<% layout("/layouts/boilerplate") %>
  <style>
    body {
      overflow: hidden !important;
    }

    .container.flex-grow-1 {
      margin: 0 !important;
      padding: 0 !important;
      max-width: 100% !important;
      height: calc(100vh - 57px) !important;
      height: calc(100dvh - 57px) !important;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .container.flex-grow-1>br,
    .container.flex-grow-1>.row {
      display: none !important;
    }

    .messenger-iframe {
      width: 100%;
      flex-grow: 1;
      border: none;
      display: block;
    }

    footer {
      display: none !important;
    }
  </style>

  <iframe
    src="https://nocapchat.onrender.com/?fbToken=<%= fbToken %><%= receiverId ? '&receiverId=' + receiverId : '' %>"
    class="messenger-iframe" title="Rentlyst Messenger" allow="microphone; camera"></iframe>