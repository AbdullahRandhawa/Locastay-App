<% layout("/layouts/boilerplate") %>
  <style>
    /* Body overflow hidden to prevent outer scroll — don't touch display/height since
       boilerplate already sets body as d-flex flex-column min-vh-100 */
    body {
      overflow: hidden !important;
    }

    /* Strip Bootstrap's default container margins and padding.
       flex-grow-1 class already makes this fill remaining height after navbar. */
    .container.flex-grow-1 {
      margin: 0 !important;
      padding: 0 !important;
      max-width: 100% !important;
      display: flex !important;
      flex-direction: column !important;
      overflow: hidden !important;
    }

    /* Hide flash-injected empty elements */
    .container.flex-grow-1>br,
    .container.flex-grow-1>.row {
      display: none !important;
    }

    /* Iframe fills all remaining space inside the container */
    .messenger-iframe {
      width: 100%;
      flex: 1 1 0;
      min-height: 0;
      border: none;
      display: block;
    }

    footer {
      display: none !important;
    }
  </style>

  <iframe id="msgIframe" class="messenger-iframe" title="Rentlyst Messenger" allow="microphone; camera"></iframe>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const iframe = document.getElementById('msgIframe');
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

      // Construct the base URL provided by EJS, attaching the client-detected theme variable
      const themeParam = isDark ? 'dark' : 'light';
      // Use the environment variable if present, otherwise fallback to local/prod defaults
      const devUrl = "http://localhost:5173";
      const prodUrl = "https://nocapchat.onrender.com";
      const baseUrl = "<%= process.env.NODE_ENV %>" === "production" ? prodUrl : devUrl;
      
      const fbToken = "<%= fbToken %>";
      const receiverId = "<%= receiverId || '' %>";
      
      let finalUrl = `${baseUrl}/?fbToken=${fbToken}&theme=${themeParam}`;
      if (receiverId) {
          finalUrl += `&receiverId=${receiverId}`;
      }
      
      iframe.src = finalUrl;
    });
  </script>