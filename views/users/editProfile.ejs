<% layout("/layouts/boilerplate") %>

    <body>
        <div class="row">
            <div class="col-10 col-lg-8 col-md-10 offset-1 offset-lg-2 offset-md-1 ">
                <br>
                <h3><% if(currUser && currUser.role === 'admin' && profile.user.toString() !== currUser._id.toString()) { %>Edit <%= profile.username %>'s Profile <% } else { %>Edit Your Profile<% } %></h3>
                <br>
                <form method="POST" action="/profile?_method=PUT" class="needs-validation" novalidate
                    enctype="multipart/form-data">

                    <% if(currUser && currUser.role === 'admin' && profile.user.toString() !== currUser._id.toString()) { %>
                        <input type="hidden" name="targetUserId" value="<%= profile.user._id %>">
                        <div class="alert alert-warning text-center small p-2">
                            <i class="fa-solid fa-shield-halved me-1"></i> You are modifying <b><%= profile.username %>'s</b> profile as an Admin.
                        </div>
                    <% } %>


                    <div class="mb-3">
                        <label for="username" class="form-label">Username</label>
                        <input type="text" name="profile[username]" value="<%= profile.username %>"
                            class="form-control" pattern="^[a-z0-9_]+$" required>
                        <div class="form-text" style="font-size: 0.8rem;">Only lowercase letters, numbers, and underscores.</div>
                    </div>
                    <br>

                    <div class="mb-3">
                        <label for="fullName" class="form-label">Full Name</label>
                        <input type="text" name="profile[fullName]" value="<%= profile.fullName %>"
                            class="form-control">
                    </div>
                    <br>

                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" name="profile[email]" value="<%= profile.email %>" class="form-control">
                    </div>
                    <br>


                    <div class="mb-3">
                        <p>Current Profile Image:</p>
                        <img src="<%= profile.profileImg.url %>" class="img-fluid rounded-circle"
                            style="width: 150px; height: 150px; object-fit: cover;">
                    </div>

                    <br>
                    <div class="mb-3">
                        <label for="profileImg" class="form-label">Update Profile Image</label>
                        <input type="file" name="profile[profileImg]" class="form-control">
                    </div>
                    <br>

                    <div class="mb-3">
                        <label for="country" class="form-label">Country</label>
                        <input type="text" name="profile[country]" value="<%= profile.country %>" class="form-control">
                    </div>
                    <br>

                    <div class="mb-3">
                        <label for="bio" class="form-label">Biography</label>
                        <textarea name="profile[bio]" class="form-control"><%= profile.bio %></textarea>
                    </div>
                    <br>

                    <div class="mb-3">
                        <label for="phoneNumber" class="form-label">Phone Number</label>
                        <input type="tel" name="profile[phoneNumber]" value="<%= profile.phoneNumber %>"
                            class="form-control">
                    </div>
                    <br>

                    <button class="btn btn-dark custom-btn">Save Profile</button>
                    <br><br><br>
                </form>

                <% if(!currUser || profile.user.toString() === currUser._id.toString()) { %>
                <hr class="my-5">

                <div class="card border-danger mb-5 p-4">
                    <div class="card-body p-4">
                        <h4 class="card-title text-danger fw-semibold mb-3">Delete Account</h4>
                        <p class="card-text text-muted mb-4">
                            Permanently delete your Rentlyst account. This action is irreversible and
                            will delete your profile, listings, and chat histories permanently.
                        </p>
                        <form class="text-end" method="POST" action="/profile/delete-account?_method=DELETE"
                            onsubmit="return confirm('WARNING: Are you absolutely sure? This will delete all your listings, reviews, messages, and profile permanently. This action cannot be undone.');">
                            <button class="btn btn-outline-danger custom-btn">Delete My Account</button>
                        </form>
                    </div>
                </div>
                <% } else { %>
                    <br><br>
                <% } %>
            </div>
        </div>
    </body>