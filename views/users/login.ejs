<% layout("/layouts/boilerplate") %>
    <style>
        footer {
            display: none !important;
        }
    </style>

    <body>
        <div class="d-flex justify-content-center align-items-center" style="min-height: calc(100vh - 120px);">
            <div class="col-12 col-lg-10 col-xl-8">
                <div class="card border-0 shadow"
                    style="border-radius: var(--radius-xl); background-color: var(--bg-main); overflow: hidden;">
                    <div class="row g-0 position-relative">
                        <!-- Shortened vertical divider -->
                        <div class="d-none d-md-block position-absolute"
                            style="width: 1px; background-color: var(--bg-tertiary); top: 15%; bottom: 15%; left: 50%;">
                        </div>



                        <div class="col-md-6 d-none d-md-flex flex-column justify-content-center p-4 p-lg-5">
                            <div class="text-center mb-4">
                                <img src="/logo-red-cropped.png" alt="R" style="height: 40px; width: auto;">
                                <h3 class="fw-bold mb-2"><span style="color: var(--primary);">Rentlyst</span>
                                </h3>

                            </div>
                            <div>
                                <div class="d-flex align-items-start mb-5">
                                    <i class="fa-solid fa-globe mt-1 me-3 fs-5" style="color: var(--primary);"></i>
                                    <div>
                                        <h6 class="fw-bold mb-1" style="font-size: 0.95rem;">Explore Globally</h6>
                                        <p class="text-muted small mb-0" style="font-size: 0.85rem; line-height: 1.5;">
                                            Access premium listings across various categories, explore unique
                                            items, and connect with users from around the world.</p>
                                    </div>
                                </div>

                                <div class="d-flex align-items-start mb-4">
                                    <i class="fa-solid fa-robot mt-1 me-3 fs-5" style="color: var(--primary);"></i>
                                    <div>
                                        <h6 class="fw-bold mb-1" style="font-size: 0.95rem;">Ask Rentlyst AI</h6>
                                        <p class="text-muted small mb-0" style="font-size: 0.85rem; line-height: 1.5;">
                                            Talk to our intelligent agent for personalized recommendations,
                                            price checks and instant help whenever you need it.
                                        </p>
                                    </div>
                                </div>

                                <div class="  d-flex align-items-start">
                                    <i class="fa-regular fa-comments mt-1 me-3 fs-5" style="color: var(--primary);"></i>
                                    <div>
                                        <h6 class="fw-bold mb-1" style="font-size: 0.95rem;">Message & Chat</h6>
                                        <p class="text-muted small mb-0" style="font-size: 0.85rem; line-height: 1.5;">
                                            Seamlessly
                                            communicate with owners and renters, negotiate terms in real-time.</p>
                                    </div>
                                </div>




                            </div>
                        </div>

                        <!-- Right Form Section -->
                        <div class="col-md-6 p-4 p-lg-5 d-flex flex-column justify-content-center">

                            <div class="text-center mb-4">
                                <h3 class="fw-bold mb-2"><span style="color: var(--primary);">Welcome </span>Back</h3>
                                <p class="text-muted" style="font-size: 0.95rem; line-height: 1.4;">Login now
                                    to pick up right where you left off on <span
                                        style="color: var(--primary);">Rentlyst</span>.</p>
                            </div>
                            <div id="login-error" class="alert alert-danger d-none py-2" role="alert"></div>

                            <form id="login-form" class="needs-validation" novalidate>
                                <div class="mb-3">
                                    <label for="loginIdentifier" class="form-label fw-semibold"
                                        style="font-size: 0.9rem;">Email or Username</label>
                                    <input type="text" name="loginIdentifier" id="loginIdentifier"
                                        class="form-control bg-light" style="padding: 0.6rem 1rem;" required>
                                </div>
                                <div class="mb-4">
                                    <label for="password" class="form-label fw-semibold"
                                        style="font-size: 0.9rem;">Password</label>
                                    <input type="password" name="password" id="password" class="form-control bg-light"
                                        style="padding: 0.6rem 1rem;" required>
                                </div>
                                <button id="login-btn" class="btn btn-primary-custom w-100 py-2 mt-2 shadow-sm"
                                    style="border-radius: var(--radius-sm);">Login</button>
                            </form>

                            <div class="mt-4 pt-1">
                                <hr class="mx-auto my-3"
                                    style="border: 0; background-color: var(--text-light); height: 1px; opacity: 0.5; width: 60%;">
                                <p class="text-center text-muted mt-3 mb-0" style="font-size: 0.9rem;">Don't have an
                                    account? <a href="/signup" class="fw-bold text-decoration-none"
                                        style="color: var(--primary);">Sign up</a></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Firebase SDK (same project as Nocap-chat) -->
        <script type="module">
            import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
            import { getAuth, signInWithEmailAndPassword } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";

            const firebaseConfig = {
                apiKey: "AIzaSyAHbmJHkxi8nOTjUjDTiuXQUW_K000VsCg",
                authDomain: "nocap-chat.firebaseapp.com",
                projectId: "nocap-chat",
                storageBucket: "nocap-chat.firebasestorage.app",
                messagingSenderId: "93908764336",
                appId: "1:93908764336:web:ae9b29ee7973d91a02dd75"
            };

            const app = initializeApp(firebaseConfig);
            const auth = getAuth(app);

            document.getElementById('login-form').addEventListener('submit', async (e) => {
                e.preventDefault();
                const btn = document.getElementById('login-btn');
                const errorBox = document.getElementById('login-error');
                errorBox.classList.add('d-none');

                let loginIdentifier = document.getElementById('loginIdentifier').value.trim();
                const password = document.getElementById('password').value;

                btn.disabled = true;
                btn.textContent = 'Logging in...';

                try {
                    let firebaseEmail = loginIdentifier;
                    // Use a proper regular expression to check if it's a valid email
                    // It must have characters, an @, a domain, a dot, and an extension (like gmail.com)
                    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                    const isEmail = emailRegex.test(firebaseEmail);

                    // If it does not match standard email patterns, assume it's a username and fetch the mapped email
                    if (!isEmail) {
                        const resolveRes = await fetch('/login/resolve-email', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ username: loginIdentifier })
                        });

                        const resolveData = await resolveRes.json();

                        if (!resolveRes.ok) {
                            throw new Error(resolveData.error || 'Username not found. Please try again.');
                        }

                        // Overwrite with the actual email before calling Firebase
                        firebaseEmail = resolveData.email;
                    }

                    // Step 1: Sign into Firebase with email + password
                    const userCredential = await signInWithEmailAndPassword(auth, firebaseEmail, password);

                    // Step 2: Get the ID token to prove identity to Express
                    const idToken = await userCredential.user.getIdToken();

                    // Step 3: Send ID token to backend to create a session cookie
                    const res = await fetch('/login', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ idToken }),
                    });

                    const data = await res.json();

                    if (!res.ok) {
                        throw new Error(data.error || 'Login failed. Please try again.');
                    }

                    // Step 4: Redirect to the intended page
                    window.location.href = data.redirect;

                } catch (err) {
                    // Make Firebase errors more user-friendly
                    let message = err.message;
                    if (err.code === 'auth/user-not-found' || err.code === 'auth/wrong-password' || err.code === 'auth/invalid-credential') {
                        message = 'Invalid email or password. Please try again.';
                    }
                    errorBox.textContent = message;
                    errorBox.classList.remove('d-none');
                    btn.disabled = false;
                    btn.textContent = 'Login';
                }
            });
        </script>
    </body>