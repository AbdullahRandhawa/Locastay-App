<% layout('/layouts/boilerplate') %>

    <body>
        <div class="container mt-5 mb-5">
            <!-- Profile Header Card -->
            <div class="row">
                <div class="col-lg-4 col-md-5 mb-4 mb-md-0">
                    <div class="card border-0 shadow-sm p-4 text-center h-100"
                        style="border-radius: var(--radius-lg); background-color: var(--bg-main);">
                        <div class="mb-3">
                            <img class="profile-img-large shadow-sm" src="<%= profile.profileImg && profile.profileImg.url ? profile.profileImg.url : 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&q=80&w=200' %>"
                                alt="Profile Image" />
                        </div>
                        <h3 class="fw-bold mb-1">
                            <%= profile.fullName || profile.username %>
                        </h3>
                        <p class="text-muted mb-4">@<%= profile.username %>
                        </p>

                        <div class="d-grid gap-2">
                            <% if(currUser && (currUser._id.equals(profile.user._id) || currUser.role === 'admin')) { %>
                                <a href="/profile/edit?id=<%= profile.user._id %>" class="btn btn-outline-dark" style="border-radius: var(--radius-sm);">Edit Profile</a>
                            <% } %>
                            
                            <% if(!currUser || !currUser._id.equals(profile.user._id)) { %>
                                <a href="/messages?receiverId=<%= profile.user %>" class="btn btn-primary-custom" style="border-radius: var(--radius-sm);">Message Host</a>
                            <% } %>
                        </div>
                    </div>
                </div>

                <div class="col-lg-8 col-md-7">
                    <div class="card border-0 shadow-sm p-4 h-100"
                        style="border-radius: var(--radius-lg); background-color: var(--bg-main);">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="fw-bold mb-0">About</h4>
                            <% if(currUser && currUser._id.equals(profile.user._id)) { %>
                                <a href="/explore/new" class="btn btn-primary-custom"><i class="fa-solid fa-plus me-2"></i>Add Listing</a>
                            <% } %>
                        </div>

                        <p class="fs-5 mb-4" style="color: var(--text-dark); line-height: 1.6;">
                            <%= profile.bio || "No bio provided yet." %>
                        </p>

                        <hr class="mb-4" style="border-color: var(--bg-tertiary);">

                        <div class="row g-4">
                            <div class="col-sm-6">
                                <p class="mb-1 text-muted fs-6"><i class="fa-solid fa-earth-americas me-2"></i> Country
                                </p>
                                <p class="fs-5 fw-semibold mb-0">
                                    <%= profile.country || "Not specified" %>
                                </p>
                            </div>
                            <div class="col-sm-6">
                                <p class="mb-1 text-muted fs-6"><i class="fa-solid fa-envelope me-2"></i> Email</p>
                                <p class="fs-5 fw-semibold mb-0">
                                    <%= profile.email %>
                                </p>
                            </div>
                            <div class="col-sm-6">
                                <p class="mb-1 text-muted fs-6"><i class="fa-solid fa-phone me-2"></i> Contact</p>
                                <p class="fs-5 fw-semibold mb-0">
                                    <%= profile.phoneNumber || "Not specified" %>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <hr class="my-5" style="border-color: var(--bg-tertiary);">

            <!-- User's Listings -->
            <div class="mb-4 text-center text-md-start">
                <h3 class="fw-bold">
                    <% if(currUser && currUser._id.equals(profile.user._id)) { %>
                        Your Listings
                    <% } else { %>
                        Listings by <%= profile.username %>
                    <% } %>
                </h3>
            </div>

            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                <% if(allListings && allListings.length> 0) { %>
                    <% for(let listing of allListings){ %>
                        <div class="col">
                            <a href="/explore/<%= listing._id %>" class="listing-link">
                                <div class="listing-card">
                                    <div class="listing-img-container position-relative">
                                        <img src="<%= listing.image && listing.image.length > 0 ? listing.image[0].url : 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&q=80&w=800' %>" class="card-img-top" alt="<%= listing.title %>">
                                        <% if(listing.listingType) { %>
                                        <span class="position-absolute top-0 end-0 m-2 badge bg-<%= listing.listingType === 'Rent' ? 'warning text-dark' : 'success' %>" style="font-size:0.7rem;"><%= listing.listingType %></span>
                                        <% } %>
                                    </div>
                                    <div class="mt-2">
                                        <div class="d-flex align-items-center gap-1 mb-1">
                                            <% if(listing.mainCategory) { %><span class="badge rounded-pill" style="background:rgba(0,0,0,0.07); color:var(--text-muted); font-size:0.65rem; font-weight:600;"><%= listing.mainCategory %></span><% } %>
                                            <% if(listing.subCategory) { %><span class="badge rounded-pill" style="background:rgba(255,56,92,0.1); color:var(--primary); font-size:0.65rem; font-weight:600;"><%= listing.subCategory %></span><% } %>
                                        </div>
                                        <p class="fw-semibold mb-0 text-truncate" style="font-size:0.95rem; color:var(--text-dark);"><%= listing.title %></p>
                                        <p class="text-muted mb-1" style="font-size:0.82rem;"><i class="fa-solid fa-location-dot me-1"></i><%= listing.city %>, <%= listing.country %></p>
                                        <p class="fw-semibold mb-0" style="color:var(--text-dark); font-size:0.95rem;">&#8360; <%= listing.price.toLocaleString('en-PK') %>
                                            <% if(listing.listingType==='Rent' && listing.rentalPeriod && listing.rentalPeriod !=='N/A') { %><span class="fw-normal text-muted" style="font-size:0.82rem;">/ <%= listing.rentalPeriod %></span><% } %>
                                        </p>
                                    </div>
                                </div>
                            </a>
                        </div>
                        <% } %>
                            <% } else { %>
                                <div class="col-12 w-100 text-center py-5">
                                    <div class="p-5 border rounded" style="background-color: var(--bg-secondary); border-color: var(--bg-tertiary) !important; border-radius: var(--radius-lg) !important;">
                                        <i class="fa-solid fa-house-chimney fs-1 text-muted mb-3"></i>
                                        <h4 class="fw-bold">No listings yet</h4>
                                        <% if(currUser && currUser._id.equals(profile.user._id)) { %>
                                            <p class="text-muted mb-4">You haven't created any listings. Start hosting today!</p>
                                            <a href="/explore/new" class="btn btn-primary-custom">Create your first listing</a>
                                        <% } else { %>
                                            <p class="text-muted mb-4">This host hasn't created any active listings.</p>
                                        <% } %>
                                    </div>
                                </div>
                                <% } %>
            </div>
        </div>
    </body>